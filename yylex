static int yy_accept_initialized = 0;

int yylex(void) {
    if (!yy_accept_initialized) {
        yy_init_accept();
        yy_accept_initialized = 1;
    }
    int yy_state, yy_last_accept, yy_accept_pos, yy_lexeme_len;
    int c;
    char yy_lexeme_buf[YY_BUF_SIZE];

    while (1) {
        yy_state = 0;
        yy_last_accept = -1;
        yy_lexeme_len = 0;

        while (1) {
            c = yy_getc();
            if (c == EOF) {
                if (yy_last_accept >= 0) goto found;
                return 0;
            }

            int next = (c >= 0 && c < 256) ? yy_nxt[yy_state][c] : -1;
            if (next < 0) break;

            yy_state = next;
            yy_lexeme_buf[yy_lexeme_len++] = (char)c;

            if (yy_accept[yy_state] >= 0) {
                yy_last_accept = yy_state;
                yy_accept_pos = yy_lexeme_len;
            }
        }

        if (c != EOF && yy_last_accept < 0) {
            yy_ungetc();
        }

        if (yy_last_accept >= 0) {
            while (yy_lexeme_len > yy_accept_pos) {
                yy_ungetc();
                yy_lexeme_len--;
            }
            yy_lexeme_buf[yy_lexeme_len] = '\0';
            yytext = strdup(yy_lexeme_buf);
            yyleng = yy_lexeme_len;

        found:
            switch (yy_accept[yy_last_accept]) {
            case 0: /* [ \t\r] */
                break;
                break;
            case 1: /* "\n" */
                ++lineno;
                break;
                break;
            case 2: /* int */
                return INT;
                break;
            case 3: /* if */
                return IF;
                break;
            case 4: /* else */
                return ELSE;
                break;
            case 5: /* return */
                return RETURN;
                break;
            case 6: /* float */
                return FLOAT;
                break;
            case 7: /* struct */
                return STRUCT;
                break;
            case 8: /* {alpha}{alphanum}* */
                yy_action_8();
                break;
            case 9: /* {digit}+ */
                yy_action_9();
                break;
            case 10: /* "(" */
                return LPAR;
                break;
            case 11: /* ")" */
                return RPAR;
                break;
            case 12: /* "{" */
                return LBRACE;
                break;
            case 13: /* "}" */
                return RBRACE;
                break;
            case 14: /* "[" */
                return LBRACK;
                break;
            case 15: /* "]" */
                return RBRACK;
                break;
            case 16: /* "==" */
                return EQUAL;
                break;
            case 17: /* "=" */
                return ASSIGN;
                break;
            case 18: /* ";" */
                return SEMICOLON;
                break;
            case 19: /* "," */
                return COMMA;
                break;
            case 20: /* "." */
                return DOT;
                break;
            case 21: /* "+" */
                return PLUS;
                break;
            case 22: /* "-" */
                return MINUS;
                break;
            case 23: /* "*" */
                return TIMES;
                break;
            case 24: /* "/" */
                return DIVIDE;
                break;
            case 25: /* . */
                yy_action_25();
                break;
            default:
                break;
            }
            continue;
        } else {
            c = yy_getc();
            if (c == EOF) return 0;
            if (c == '\n') { yylineno++; continue; }
            /* Fallback: match exactly one character */
            yytext = (char*)malloc(2);
            yytext[0] = (char)c;
            yytext[1] = '\0';
            yyleng = 1;
            /* Rule 25 (wildcard) */
            {
                
			fprintf(stderr,
				"Illegal character with code %d on line #%d\n",
				*yytext, lineno);
			exit(1);
            }
            continue;
        }
    }
}

int main(int argc, char* argv[]) {
    if (argc > 1) {
        FILE* f = fopen(argv[1], "r");
        if (f) {
            yy_buf_end = fread(yy_buffer, 1, YY_BUF_SIZE, f);
            fclose(f);
            yy_buf_pos = 0;
        }
    }
    yy_init_accept();
    yylex();
    return 0;
}

